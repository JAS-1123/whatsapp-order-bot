{
  "name": "whatsapp-ordering-bot",
  "version": "1.0.0",
  "description": "WhatsApp Ordering Bot Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run dev:full",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:ngrok": "node scripts/start-ngrok.js",
    "dev:admin": "cd admin-dashboard && npm run dev -- -p 3001",
    "dev:full": "concurrently -k \"npm run dev:server\" \"npm run dev:ngrok\" \"npm run dev:admin\"",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "prisma": {
    "seed": "ts-node-dev prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.7.8",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "uuid": "^14.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
